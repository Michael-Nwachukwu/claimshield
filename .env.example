# ClaimShield — Environment Variables
# Copy this to .env and fill in your values before running any scripts.
# NEVER commit .env to git.

# ── Tenderly Virtual Testnet ─────────────────────────────────────────────────
# Create a virtual testnet at https://dashboard.tenderly.co/
# Set it to fork mainnet so real USDC is available
TENDERLY_RPC_URL=https://virtual.mainnet.rpc.tenderly.co/YOUR_SLUG
TENDERLY_ACCESS_KEY=...
TENDERLY_ACCOUNT_SLUG=...
TENDERLY_PROJECT_SLUG=...

# ── Wallets ──────────────────────────────────────────────────────────────────
# DEPLOYER: deploys contracts, runs Seed.s.sol, funds the settlement pool
DEPLOYER_PRIVATE_KEY=0x...

# ENCLAVE: separate wallet — this is the approved enclave signer
# Its address must match ENCLAVE_WALLET_ADDRESS registered in PolicyRegistry
# In production CRE, this wallet is managed by the DON (not a raw private key)
ENCLAVE_PRIVATE_KEY=0x...
ENCLAVE_WALLET_ADDRESS=0x...

# CLAIMANT: the wallet that owns policy DEMO-001
# For demo: same as deployer (simpler setup)
CLAIMANT_WALLET=0x...

# ── Deployed Contract Addresses ───────────────────────────────────────────────
# Populate these after running: forge script script/Deploy.s.sol --broadcast
POLICY_REGISTRY_ADDRESS=0x...
CLAIM_REQUEST_ADDRESS=0x...
CLAIM_SETTLEMENT_ADDRESS=0x...

# ── Enclave Encryption ───────────────────────────────────────────────────────
# Shared secret for encrypting the FHIR claim ID in the ClaimSubmitted event.
# The enclave decrypts it from the event data — the FHIR ID never appears onchain.
# Production CRE: replaced by the DON's asymmetric keypair (Vault DON managed).
ENCLAVE_SHARED_SECRET=0xf2eb356e687a4ab94222cdc11a4bfb9fb21686c150d4be4340b3d328fdda9932

# ── CRE Workflow ──────────────────────────────────────────────────────────────
# Used by workflow/main.ts via secrets.yaml → vaultDonSecrets
# Demo: public HAPI FHIR sandbox requires no auth token (leave as placeholder)
# Production: set to your real EHR OAuth2 bearer token
EHR_AUTH_TOKEN_ALL=demo_placeholder_no_auth_required_for_hapi_fhir_sandbox

# CRE CLI authentication (for cre workflow simulate / deploy)
CRE_ETH_PRIVATE_KEY=0x...
CRE_TARGET=staging-settings

# ── World ID ──────────────────────────────────────────────────────────────────
# Obtain from https://developer.worldcoin.org/ (create app, set env to Staging)
# The app_id starts with "app_"
WORLD_ID_APP_ID=app_...

# The action string you created inside your World ID app (e.g. "submit-claim")
# Must exactly match the Action name in the Developer Portal.
WORLD_ID_ACTION=submit-claim
