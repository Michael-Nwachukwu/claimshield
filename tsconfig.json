{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "ES2020"
        ],
        "strict": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "outDir": "dist",
        "rootDir": ".",
        "skipLibCheck": true
    },
    "include": [
        "enclave/**/*",
        "scripts/**/*",
        "workflow/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "lib"
    ]
}